# ── NextAuth ──────────────────────────────────────────────────────────────────
# LOCAL:  http://localhost:3000
# VERCEL: https://your-app.vercel.app  (set after first deploy)
NEXTAUTH_URL=http://localhost:3000

# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET=replace-with-64-char-hex-string

# ── Google Service Account ─────────────────────────────────────────────────────
# 1. console.cloud.google.com → Create project
# 2. Enable APIs: Google Sheets API, Google Drive API
# 3. IAM → Service Accounts → Create → Download JSON key
# 4. Share your Google Sheet with the service account email (Editor role)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com

# Copy private_key value from JSON file (keep the \n escape sequences as-is)
# VERCEL: paste the full value including -----BEGIN/END----- with \n — do NOT wrap in quotes
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ── Existing Google Sheet (no migration needed) ────────────────────────────────
GOOGLE_SPREADSHEET_ID=1m_3t3N0KGT7NwV1usGyjL_-D231tgACOb2-_Bmpd9dk

# ── Existing Google Drive folder for attachments ──────────────────────────────
GOOGLE_DRIVE_FOLDER_ID=1kwlRhKqU3QD67HjW5qXA5MmkClHeH5Aa
